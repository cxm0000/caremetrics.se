---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import FeatureIcon from '../../components/FeatureIcon.astro';
import { siteConfig } from '../../config/site';
import { getTranslations, getLocalizedPath, type Language, supportedLanguages, defaultLanguage } from '../../i18n/utils';

export async function getStaticPaths() {
  return supportedLanguages.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<Layout>
  <Hero lang={lang} />
  
  <section id="features" class="features-section" aria-labelledby="features-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="features-heading">{t.features.title}</h2>
        <p class="section-subtitle" set:html={t.features.subtitle} />
      </div>
      
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-header">
            <FeatureIcon name="check" />
            <h3>{t.features.dataValidation.title}</h3>
          </div>
          <p set:html={t.features.dataValidation.description} />
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <FeatureIcon name="chart" />
            <h3>{t.features.qualityScorecards.title}</h3>
          </div>
          <p set:html={t.features.qualityScorecards.description} />
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <FeatureIcon name="trend" />
            <h3>{t.features.benchmarking.title}</h3>
          </div>
          <p>{t.features.benchmarking.description}</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <FeatureIcon name="lightning" />
            <h3>{t.features.dashboards.title}</h3>
          </div>
          <p set:html={t.features.dashboards.description} />
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <FeatureIcon name="referral" />
            <h3>{t.features.referrals.title}</h3>
          </div>
          <p>{t.features.referrals.description}</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <FeatureIcon name="lock" />
            <h3>{t.features.security.title}</h3>
          </div>
          <p>{t.features.security.description}</p>
        </div>
      </div>
    </div>
  </section>
  
  <section class="analytics-preview" aria-labelledby="analytics-heading">
    <div class="container">
      <div class="analytics-header">
        <h2 id="analytics-heading">
          {lang === 'sv' ? 'Exempel på CareMetrics‑grafer' : 'Example CareMetrics Analytics'}
        </h2>
        <p class="analytics-subtitle">
          {lang === 'sv'
            ? 'Illustrativa exempel på hur diagnoser, väntetider och behandlingstider kan visualiseras i CareMetrics.'
            : 'Illustrative examples of how diagnoses, waiting times and treatment times can be visualised in CareMetrics.'}
        </p>
      </div>
      
      <div class="analytics-grid">
        <div class="analytics-grid-left">
          <div class="analytics-card">
          <div class="analytics-card-header">
            <span class="analytics-pill">
              {lang === 'sv' ? 'Fördelning' : 'Distribution'}
            </span>
            <h3>
              {lang === 'sv' ? 'Diagnosfördelning' : 'Diagnosis distribution'}
            </h3>
          </div>
          <p class="analytics-card-copy">
            {lang === 'sv'
              ? 'Exempel på hur registrerade diagnoser kan visas som fördelningsdiagram med en stapel per diagnos.'
              : 'Example of how registered diagnoses can be shown as a distribution chart with one bar per diagnosis.'}
          </p>
          <div class="analytics-chart analytics-chart--bars" aria-hidden="true">
            <div class="bar bar--primary" style="height: 72%">
              <span class="bar-label">Pulpitis</span>
              <span class="bar-value">42</span>
            </div>
            <div class="bar bar--primary" style="height: 56%">
              <span class="bar-label">Apikal</span>
              <span class="bar-value">31</span>
            </div>
            <div class="bar bar--primary" style="height: 38%">
              <span class="bar-label">Kronisk</span>
              <span class="bar-value">18</span>
            </div>
            <div class="bar bar--muted" style="height: 22%">
              <span class="bar-label">
                {lang === 'sv' ? 'Övrigt' : 'Other'}
              </span>
              <span class="bar-value">9</span>
            </div>
          </div>
          </div>
          
          <div class="analytics-card">
          <div class="analytics-card-header">
            <span class="analytics-pill">
              {lang === 'sv' ? 'Väntetid' : 'Waiting time'}
            </span>
            <h3>
              {lang === 'sv' ? 'Remiss till besök' : 'Referral to visit'}
            </h3>
          </div>
          <p class="analytics-card-copy">
            {lang === 'sv'
              ? 'Illustration av hur väntetid mellan remissdatum och besöksdatum kan grupperas i spann.'
              : 'Illustration of how waiting time from referral date to visit date can be grouped into ranges.'}
          </p>
          <div class="analytics-chart analytics-chart--horizontal" aria-hidden="true">
            <div class="hbar">
              <span class="hbar-label">0–1 mån</span>
              <div class="hbar-track">
                <div class="hbar-fill hbar-fill--primary" style="width: 55%"></div>
              </div>
              <span class="hbar-value">55%</span>
            </div>
            <div class="hbar">
              <span class="hbar-label">1–3 mån</span>
              <div class="hbar-track">
                <div class="hbar-fill hbar-fill--primary" style="width: 30%"></div>
              </div>
              <span class="hbar-value">30%</span>
            </div>
            <div class="hbar">
              <span class="hbar-label">3–6 mån</span>
              <div class="hbar-track">
                <div class="hbar-fill hbar-fill--muted" style="width: 10%"></div>
              </div>
              <span class="hbar-value">10%</span>
            </div>
            <div class="hbar">
              <span class="hbar-label">{lang === 'sv' ? '> 6 mån' : '&gt; 6 mo'}</span>
              <div class="hbar-track">
                <div class="hbar-fill hbar-fill--muted" style="width: 5%"></div>
              </div>
              <span class="hbar-value">5%</span>
            </div>
          </div>
          </div>
        </div>
        
        <div class="analytics-grid-right">
          <div class="analytics-card analytics-card--primary">
          <div class="analytics-card-header">
            <span class="analytics-pill">
              {lang === 'sv' ? 'Behandlingstid' : 'Treatment time'}
            </span>
            <h3>
              {lang === 'sv' ? 'Tidsintervall (30–400 min)' : 'Duration buckets (30–400 min)'}
            </h3>
          </div>
          <p class="analytics-card-copy">
            {lang === 'sv'
              ? 'Exempel på uppdelning av behandlingstider i intervall med antal fall per spann.'
              : 'Example of splitting procedure durations into buckets with case counts per range.'}
          </p>
          <div class="analytics-chart analytics-chart--stacked" aria-hidden="true">
            <div class="stack-row">
              <span class="stack-label">30–60</span>
              <div class="stack-track">
                <div class="stack-segment stack-segment--primary" style="width: 40%"></div>
                <div class="stack-segment stack-segment--muted" style="width: 60%"></div>
              </div>
              <span class="stack-value">80</span>
            </div>
            <div class="stack-row">
              <span class="stack-label">61–120</span>
              <div class="stack-track">
                <div class="stack-segment stack-segment--primary" style="width: 35%"></div>
                <div class="stack-segment stack-segment--muted" style="width: 65%"></div>
              </div>
              <span class="stack-value">70</span>
            </div>
            <div class="stack-row">
              <span class="stack-label">121–180</span>
              <div class="stack-track">
                <div class="stack-segment stack-segment--primary" style="width: 15%"></div>
                <div class="stack-segment stack-segment--muted" style="width: 85%"></div>
              </div>
              <span class="stack-value">30</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <section id="about" class="about-section" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <h2 id="about-heading">{t.about.title}</h2>
          <p>
            {t.about.paragraph1}
          </p>
          <p set:html={t.about.paragraph2} />
          <p>
            {t.about.paragraph3}
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <section id="contact" class="contact-section" aria-labelledby="contact-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="contact-heading">{t.contact.title}</h2>
        <p class="section-subtitle" set:html={t.contact.subtitle} />
      </div>
      
      <div class="contact-content">
        <div class="contact-info">
          <p set:html={t.contact.description} />
          <p>
            <strong>{t.contact.email}</strong> <a href={`mailto:${siteConfig.contact.primaryEmail}`}>{siteConfig.contact.primaryEmail}</a>
          </p>
          <p>
            {t.contact.closing}
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .features-section {
    background:
      radial-gradient(circle at 0% 0%, rgba(15, 159, 183, 0.12), transparent 55%),
      radial-gradient(circle at 100% 0%, rgba(29, 78, 216, 0.10), transparent 55%),
      var(--color-bg-secondary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .feature-card {
    background: radial-gradient(circle at 0% 0%, rgba(15, 159, 183, 0.08), transparent 55%), #ffffff;
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(148, 163, 184, 0.35);
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease, background 0.28s ease;
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 26px 60px rgba(15, 23, 42, 0.16);
    border-color: rgba(15, 159, 183, 0.7);
    background:
      radial-gradient(circle at 0% 0%, rgba(15, 159, 183, 0.16), transparent 55%),
      radial-gradient(circle at 100% 100%, rgba(29, 78, 216, 0.16), transparent 60%),
      #ffffff;
  }

  .feature-card:hover h3 {
    color: var(--color-primary);
  }

  .feature-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1.5rem;
    margin: 0;
    color: var(--color-text);
    overflow-wrap: break-word;
    word-wrap: break-word;
    hyphens: auto;
    line-height: 1.3;
    flex: 1;
    min-width: 0;
  }

  .feature-card p {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
    overflow-wrap: break-word;
    word-wrap: break-word;
    hyphens: auto;
  }

  .about-section {
    background:
      linear-gradient(135deg, #f8fafc 0%, #ffffff 40%, #e0f2fe 100%);
  }

  .about-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-text h2 {
    margin-bottom: 1.5rem;
  }

  .about-text p {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
  }

  .contact-section {
    background:
      radial-gradient(circle at 0% 0%, rgba(15, 159, 183, 0.18), transparent 60%),
      radial-gradient(circle at 100% 0%, rgba(29, 78, 216, 0.18), transparent 60%),
      linear-gradient(135deg, #0b1727 0%, #020617 100%);
    color: #e2e8f0;
  }

  .contact-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-info p {
    font-size: 1.125rem;
    color: #cbd5f5;
    margin-bottom: 1rem;
  }

  .contact-info strong {
    color: #e5e7eb;
  }

  .contact-info a {
    color: #38bdf8;
    font-weight: 600;
    text-decoration: none;
  }

  .contact-info a:hover {
    text-decoration: underline;
  }

  .analytics-preview {
    background: var(--color-bg);
  }

  .analytics-header {
    text-align: left;
    max-width: 720px;
    margin: 0 auto 3rem;
  }

  .analytics-header h2 {
    font-size: clamp(1.9rem, 3vw, 2.4rem);
    margin-bottom: 0.75rem;
  }

  .analytics-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    max-width: 640px;
  }

  .analytics-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.4fr);
    gap: 2.25rem;
    align-items: stretch;
  }

  .analytics-grid-left {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .analytics-grid-right {
    display: flex;
    height: 100%;
  }

  .analytics-card {
    background: #ffffff;
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    border: 1px solid rgba(226, 232, 240, 0.9);
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .analytics-card--primary {
    width: 100%;
  }

  .analytics-card-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .analytics-card-header h3 {
    font-size: 1.1rem;
    margin: 0;
    color: var(--color-text);
  }

  .analytics-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(20, 184, 166, 0.08);
    color: var(--color-primary);
  }

  .analytics-card-copy {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .analytics-chart {
    border-radius: 1rem;
    padding: 1rem;
    background: radial-gradient(circle at 0% 0%, rgba(20, 184, 166, 0.06), transparent 55%),
      radial-gradient(circle at 100% 100%, rgba(15, 23, 42, 0.06), transparent 55%),
      #f8fafc;
    border: 1px dashed rgba(148, 163, 184, 0.6);
  }

  .analytics-chart--bars {
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
    height: 180px;
  }

  .bar {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    gap: 0.25rem;
  }

  .bar::before {
    content: '';
    display: block;
    width: 100%;
    border-radius: 999px 999px 4px 4px;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.1), rgba(15, 23, 42, 0.02));
  }

  .bar--primary::before {
    background: linear-gradient(180deg, rgba(20, 184, 166, 0.85), rgba(20, 184, 166, 0.5));
  }

  .bar--muted::before {
    background: linear-gradient(180deg, rgba(148, 163, 184, 0.9), rgba(148, 163, 184, 0.5));
  }

  .bar::before {
    height: 100%;
  }

  .bar-label {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .bar-value {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .analytics-chart--horizontal {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .hbar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
  }

  .hbar-label {
    color: var(--color-text-secondary);
  }

  .hbar-track {
    position: relative;
    height: 0.6rem;
    border-radius: 999px;
    background: rgba(148, 163, 184, 0.25);
    overflow: hidden;
  }

  .hbar-fill {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .hbar-fill--primary {
    background: linear-gradient(90deg, var(--color-primary), rgba(20, 184, 166, 0.6));
  }

  .hbar-fill--muted {
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.9), rgba(148, 163, 184, 0.5));
  }

  .hbar-value {
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
    font-weight: 600;
  }

  .analytics-chart--stacked {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    font-size: 0.8rem;
  }

  .stack-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.5rem;
    align-items: center;
  }

  .stack-label {
    color: var(--color-text-secondary);
  }

  .stack-track {
    position: relative;
    height: 0.6rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.08);
    overflow: hidden;
    display: flex;
  }

  .stack-segment {
    height: 100%;
  }

  .stack-segment--primary {
    background: linear-gradient(90deg, var(--color-primary), rgba(20, 184, 166, 0.7));
  }

  .stack-segment--muted {
    background: rgba(148, 163, 184, 0.4);
  }

  .stack-value {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .feature-card {
      padding: 1.5rem;
    }

    .section-header {
      margin-bottom: 2rem;
    }

    .analytics-header,
    .analytics-grid {
      margin-bottom: 2rem;
    }

    .analytics-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>

