---
import { siteConfig } from '../config/site';
import { getTranslations, getLocalizedPath, type Language } from '../i18n/utils';

interface Props {
  lang?: Language;
}

const currentLang = Astro.props.lang || 'sv';
const t = getTranslations(currentLang);
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <img src="/logo-dark.svg" alt={siteConfig.name} class="footer-logo" width="120" height="32" />
        <p class="footer-tagline">{siteConfig.tagline}</p>
      </div>
      <div class="footer-section">
        <h4 class="footer-heading">{t.footer.quickLinks}</h4>
        <ul class="footer-links">
          <li><a href={getLocalizedPath('/#features', currentLang)}>{t.nav.features}</a></li>
          <li><a href={getLocalizedPath('/#about', currentLang)}>{t.nav.about}</a></li>
          <li><a href={getLocalizedPath('/#contact', currentLang)}>{t.nav.contact}</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4 class="footer-heading">{t.footer.legal}</h4>
        <ul class="footer-links">
          <li><a href={getLocalizedPath('/privacy', currentLang)}>{t.footer.privacy}</a></li>
          <li><a href={getLocalizedPath('/terms', currentLang)}>{t.footer.terms}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {siteConfig.company.year} {siteConfig.company.name}. {t.footer.rights}.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(circle at 0% 0%, rgba(15, 159, 183, 0.18), transparent 60%),
      radial-gradient(circle at 100% 0%, rgba(29, 78, 216, 0.18), transparent 60%),
      #020617;
    border-top: 1px solid rgba(15, 23, 42, 0.9);
    padding: 3rem 0 1.5rem;
    margin-top: 4rem;
    color: #e5e7eb;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-logo {
    height: 32px;
    width: auto;
    margin-bottom: 0.5rem;
    opacity: 0.9;
  }

  .footer-tagline {
    color: #9ca3af;
    font-size: 0.9rem;
  }

  .footer-heading {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #e5e7eb;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s;
    font-size: 0.9rem;
  }

  .footer-links a:hover {
    color: #38bdf8;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    color: #9ca3af;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>

